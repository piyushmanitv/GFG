Binary Strings with Equal Sum of Two Halves
Difficulty: MediumAccuracy: 41.34%Submissions: 27K+Points: 4Average Time: 20m
Given a number n, find count of all binary sequences of length 2n such that sum of first n bits is same as sum of last n bits. 

Note: Since the anwer can be very large, so return the answer modulo 109+7.












class Solution {
  public:
    
    long long power(long long base, long long exp, long long mod) {
        long long result = 1;
        
        while (exp > 0) {
            if (exp & 1)
                result = (result * base) % mod;
            
            base = (base * base) % mod;
            exp >>= 1;
        }
        
        return result;
    }
    
    int computeValue(int n) {
        const long long MOD = 1000000007;
        
        long long fact2n = 1;
        long long factn = 1;
        
        for (int i = 1; i <= 2 * n; i++) {
            fact2n = (fact2n * i) % MOD;
            
            if (i == n)
                factn = fact2n;
        }
        
        long long invFactn = power(factn, MOD - 2, MOD);
        
        long long ans = fact2n;
        ans = (ans * invFactn) % MOD;
        ans = (ans * invFactn) % MOD;
        
        return (int)ans;
    }
};
